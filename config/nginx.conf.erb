daemon off;
worker_processes <%= ENV['NGINX_WORKERS'] || 4 %>;

events {
  use epoll;
  accept_mutex on;
  worker_connections 1024;
}

http {
  gzip on;
  gzip_comp_level 5;
  gzip_min_length 256;
  gzip_proxied any;
  gzip_vary on;
  gzip_types
    application/javascript
    application/json
    application/xml
    application/x-font-ttf
    application/vnd.ms-fontobject
    font/opentype
    image/svg+xml
    text/css
    text/plain
    text/xml;

  server_tokens off;

  log_format l2met 'measure#nginx.service=$request_time request_id=$http_x_request_id';
  access_log /dev/stdout l2met;
  error_log /dev/stderr;

  include mime.types;
  default_type application/octet-stream;
  sendfile on;

  client_body_timeout 5;

  server {
    listen <%= ENV['PORT'] %>;
    server_name _;
    keepalive_timeout 5;

    root /app/;
    index index.html;

    # Cache long pour assets statiques
    location ~* \.(?:css|js|woff2?|ttf|otf|eot|svg|png|jpe?g|webp|avif|ico|gif)$ {
      expires 1y;
      add_header Cache-Control "public, immutable";
      access_log off;
    }

    # Pages HTML : pas de cache agressif
    location ~* \.html$ {
      expires -1;
      add_header Cache-Control "no-cache, must-revalidate";
    }

    # Routing : on essaie le fichier, puis le dossier, puis 404
    location / {
      try_files $uri $uri/ $uri.html =404;
    }

    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;
  }
}
