# Inclus dans le bloc server { } du buildpack nginx Scalingo
# Le bloc http {}, server { listen, server_name, root } est défini par base_nginx.conf.erb

# --- Headers de sécurité ---
add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
add_header X-Content-Type-Options "nosniff" always;
add_header X-Frame-Options "SAMEORIGIN" always;
add_header Referrer-Policy "strict-origin-when-cross-origin" always;
add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()" always;

# CSP : autorise self + FormSubmit (AJAX), inline pour onclick handlers et styles inline
add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://formsubmit.co; form-action 'self' https://formsubmit.co; frame-ancestors 'self'; base-uri 'self'; object-src 'none'" always;

# Cache long pour les assets statiques (1 an, immutables)
location ~* \.(?:css|js|woff2?|ttf|otf|eot|svg|png|jpe?g|webp|avif|ico|gif)$ {
  expires 1y;
  add_header Cache-Control "public, immutable";
  add_header X-Content-Type-Options "nosniff";
  access_log off;
}

# Pages HTML : pas de cache agressif (mises à jour fréquentes)
location ~* \.html$ {
  expires -1;
  add_header Cache-Control "no-cache, must-revalidate";
}

# robots.txt et sitemap.xml servis directement
location = /robots.txt {
  access_log off;
  log_not_found off;
}
location = /sitemap.xml {
  access_log off;
  log_not_found off;
}

# Bloquer User-Agents malveillants / scrapers connus
if ($http_user_agent ~* (AhrefsBot|SemrushBot|DotBot|MJ12bot|PetalBot)) {
  return 403;
}

# Routing : on essaie le fichier, puis le dossier, puis ajoute .html, puis 404
location / {
  try_files $uri $uri/ $uri.html =404;
}

error_page 404 /404.html;
error_page 500 502 503 504 /50x.html;
